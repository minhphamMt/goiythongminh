# Google Cloud Storage
GCS_BUCKET=your-bucket
GCS_PROJECT_ID=your-project-id
GCS_KEY_FILE=
GCS_SERVICE_ACCOUNT_JSON=

# Database
DB_HOST=your-tidb-host
DB_PORT=4000
DB_USER=your-user
DB_PASS=your-password
DB_NAME=music_platform

# Model artifacts
METADATA_MODEL_PATH=
METADATA_MODEL_URL=
AUDIO_MODEL_PATH=
AUDIO_MODEL_URL=
ARTIFACT_CACHE_DIR=.cache

# Audio tuning
AUDIO_DOWNLOAD_WORKERS=10
AUDIO_PREFETCH=40
AUDIO_SEGMENT_BATCH=32
AUDIO_DOWNLOAD_RETRIES=2
AUDIO_MIN_ANALYSIS_SEC=5

# Worker settings
WORKER_IDLE_SLEEP_SECONDS=3
WORKER_RETRY_DELAY_SECONDS=30
WORKER_MAX_ATTEMPTS=3
EMBEDDING_RUN_METADATA_WORKER=true
EMBEDDING_RUN_AUDIO_WORKER=true
SUPERVISOR_POLL_SECONDS=5
SUPERVISOR_STOP_TIMEOUT_SECONDS=20

# API
EMBEDDING_API_HOST=0.0.0.0
EMBEDDING_API_PORT=8000
EMBEDDING_API_TOKEN=
